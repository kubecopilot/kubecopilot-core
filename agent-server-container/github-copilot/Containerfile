FROM node:22-slim AS base

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git python3 python3-pip python3-venv ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | \
    dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list && \
    apt-get update && apt-get install -y gh && rm -rf /var/lib/apt/lists/*

# Install the GitHub Copilot CLI binary (separate from gh CLI).
# Requires Node 22+. Installs 'copilot' binary that 'gh copilot' delegates to.
RUN npm install -g @github/copilot

# Install kubectl (latest stable)
RUN curl -fsSL "https://dl.k8s.io/release/$(curl -sL https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl" \
    -o /usr/local/bin/kubectl && chmod +x /usr/local/bin/kubectl

# Install oc CLI (OpenShift client — same binary as kubectl + oc extensions)
RUN curl -fsSL "https://mirror.openshift.com/pub/openshift-v4/clients/ocp/stable/openshift-client-linux.tar.gz" \
    | tar -xz -C /usr/local/bin oc && chmod +x /usr/local/bin/oc

RUN useradd -m -s /bin/bash copilot
WORKDIR /home/copilot

# Python venv for the HTTP shim
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
RUN pip install --no-cache-dir fastapi uvicorn httpx github-copilot-sdk \
    opentelemetry-sdk \
    opentelemetry-exporter-otlp-proto-http

COPY entrypoint.sh /entrypoint.sh
COPY server.py /server.py
RUN chmod +x /entrypoint.sh && \
    # OpenShift runs with arbitrary UIDs in the root group — make home group-writable
    chown -R copilot:root /home/copilot && \
    chmod -R g+rwX /home/copilot

USER copilot
EXPOSE 8080
ENTRYPOINT ["/entrypoint.sh"]
